# Azure Authentication (standard Azure SDK variables)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# DFO Configuration (all DFO-specific variables use DFO_ prefix)
# See CODE_STYLE.md for naming conventions

# Azure Pricing API Configuration
DFO_AZURE_PRICING_API_URL=https://prices.azure.com/api/retail/prices
DFO_PRICING_CACHE_TTL_DAYS=7

# Analysis Configuration
DFO_IDLE_CPU_THRESHOLD=5.0
DFO_IDLE_DAYS=14
DFO_DRY_RUN_DEFAULT=true

# Rules Configuration
# Comma-separated list of rule types to disable (overrides optimization_rules.json)
# Example: DFO_DISABLE_RULES="Right-Sizing (CPU),Shutdown Detection"
# DFO_DISABLE_RULES=

# Service Type Filtering
# Comma-separated list of service types to enable (default: all)
# Available types: vm, database, storage, networking, app-service, aks
# Example: DFO_SERVICE_TYPES="vm,database"
# Leaving empty enables all service types
# DFO_SERVICE_TYPES=

# Database Configuration
DFO_DUCKDB_FILE=./dfo.duckdb

# Logging Configuration
DFO_LOG_LEVEL=INFO

# Debug Mode (set to any value to enable detailed tracebacks)
# DFO_DEBUG=1
