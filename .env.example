# Azure Authentication (standard Azure SDK variables)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# DFO Configuration (all DFO-specific variables use DFO_ prefix)
# See CODE_STYLE.md for naming conventions

# Azure Pricing API Configuration
DFO_AZURE_PRICING_API_URL=https://prices.azure.com/api/retail/prices
DFO_PRICING_CACHE_TTL_DAYS=7

# Analysis Configuration
# Idle VM Detection - detects VMs with consistently low CPU usage
DFO_IDLE_CPU_THRESHOLD=5.0
DFO_IDLE_DAYS=14

# Right-Sizing (CPU) - detects VMs that can be downsized based on CPU usage
DFO_RIGHTSIZING_CPU_THRESHOLD=20.0
DFO_RIGHTSIZING_DAYS=14

# Shutdown Detection - detects VMs that have been stopped/deallocated
DFO_SHUTDOWN_DAYS=30

# General execution settings
DFO_DRY_RUN_DEFAULT=true

# ============================================================================
# DIRECT EXECUTION (Advanced Feature - DISABLED by default)
# ============================================================================
#
# Direct execution allows single-command resource modifications without
# the plan-based workflow (create → validate → approve → execute).
#
# ⚠ WARNING: This is a powerful feature that bypasses safety gates.
# Only enable in:
#   - Development/testing environments
#   - Emergency response scenarios
#   - Environments with strict access controls
#
# DO NOT enable in production without proper access controls and audit procedures.
#
# Default: false (disabled)
# Recommendation: Use plan-based execution for production workflows
# See: docs/EXECUTION_WORKFLOW_GUIDE.md and docs/FEATURE_DIRECT_EXECUTION.md
#
DFO_ENABLE_DIRECT_EXECUTION=false

# Action Log Retention
# How long to keep execution logs in the database
DFO_ACTION_LOG_RETENTION_DAYS=365        # Live executions (1 year)
DFO_DRYRUN_LOG_RETENTION_DAYS=90         # Dry-run simulations (90 days)

# Rules Configuration
# Comma-separated list of rule types to disable (overrides optimization_rules.json)
# Example: DFO_DISABLE_RULES="Right-Sizing (CPU),Shutdown Detection"
# DFO_DISABLE_RULES=

# Service Type Filtering
# Comma-separated list of service types to enable (default: all)
# Available types: vm, database, storage, networking, app-service, aks
# Example: DFO_SERVICE_TYPES="vm,database"
# Leaving empty enables all service types
# DFO_SERVICE_TYPES=

# Database Configuration
DFO_DUCKDB_FILE=./dfo.duckdb

# Logging Configuration
DFO_LOG_LEVEL=INFO

# Debug Mode (set to any value to enable detailed tracebacks)
# DFO_DEBUG=1
