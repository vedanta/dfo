{
  "optimizations": [
    {
      "service_type": "vm",
      "layer": 1,
      "sub_layer": "Self-Contained VM",
      "type": "Right-Sizing (CPU)",
      "key": "low-cpu",
      "category": "compute",
      "description": "Identify VMs with consistently low CPU utilization for downsizing",
      "module": "low_cpu",
      "metric": "CPU utilization",
      "threshold": "<20%",
      "period": "14d",
      "unit": "percent",
      "enabled": true,
      "actions": ["resize", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Azure Monitor: Percentage CPU",
        "aws": "AWS: CPUUtilization",
        "gcp": "GCP: cpu/utilization"
      }
    },
    {
      "service_type": "vm",
      "layer": 1,
      "sub_layer": "Self-Contained VM",
      "type": "Right-Sizing (Memory)",
      "key": "low-memory",
      "category": "compute",
      "description": "Identify VMs with consistently low memory utilization for downsizing",
      "module": "low_memory",
      "metric": "Memory utilization",
      "threshold": "<30%",
      "period": "14d",
      "unit": "percent",
      "enabled": false,
      "actions": ["resize", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Azure Monitor: Memory Percent Used",
        "aws": "AWS: mem_used_percent",
        "gcp": "GCP: memory/percent_used"
      }
    },
    {
      "service_type": "vm",
      "layer": 1,
