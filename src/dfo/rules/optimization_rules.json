      "category": "compute",
      "description": "Detect underutilized VMs based on CPU and RAM metrics over time",
      "module": "idle_vms",
      "metric": "CPU/RAM <5%",
      "threshold": "<5%",
      "period": "7d",
      "unit": "percent",
      "enabled": true,
      "actions": ["stop", "deallocate", "delete"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "CPU% + RAM% time series",
        "aws": "AWS: CPUUtilization + mem_used_percent",
        "gcp": "GCP: low CPU+RAM"
      }
    },
