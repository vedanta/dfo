{
  "service": "storage",
  "version": "1.0",
  "description": "Azure Storage optimization rules covering blob storage, file shares, data lakes, and storage account management",
  "rules": [
    {
      "service_type": "storage",
      "layer": 1,
      "sub_layer": "Self-Contained Storage",
      "type": "Tiering Optimization",
      "key": "storage-tiering",
      "category": "storage",
      "description": "Identify infrequently accessed data suitable for Cool or Archive tiers",
      "module": "storage_tiering",
      "metric": "Last access time",
      "threshold": ">30d",
      "period": "30d",
      "unit": "days",
      "enabled": true,
      "actions": ["re-tier", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Blob accessTime",
        "aws": "S3 object last accessed",
        "gcp": "GCS object access timestamp"
      }
    },
    {
      "service_type": "storage",
      "layer": 1,
      "sub_layer": "Self-Contained Storage",
      "type": "Orphaned Blob Cleanup",
      "key": "orphaned-blobs",
      "category": "storage",
      "description": "Detect blobs without recent access or active references",
      "module": "orphaned_blobs",
      "metric": "Access time",
      "threshold": ">90d",
      "period": "90d",
      "unit": "days",
      "enabled": false,
      "actions": ["delete", "snapshot", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Blob accessTime",
        "aws": "S3 object unused status",
        "gcp": "GCS access logs"
      }
    },
    {
      "service_type": "storage",
      "layer": 1,
      "sub_layer": "Self-Contained Storage",
      "type": "Snapshot/Version Cleanup",
      "key": "stale-snapshots",
      "category": "storage",
      "description": "Identify stale snapshots and versions contributing to cost growth",
      "module": "stale_snapshots",
      "metric": "Snapshot age",
      "threshold": ">60d",
      "period": "60d",
      "unit": "days",
      "enabled": false,
      "actions": ["delete", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Blob snapshots",
        "aws": "S3 versioning",
        "gcp": "GCS object versions"
      }
    },
    {
      "service_type": "storage",
      "layer": 1,
      "sub_layer": "Self-Contained Storage",
      "type": "High Transaction Cost Detection",
      "key": "storage-transaction-cost",
      "category": "cost",
      "description": "Detect accounts where transaction charges exceed expected thresholds",
      "module": "storage_transaction_cost",
      "metric": "Transaction-to-storage ratio",
      "threshold": ">1.5x",
      "period": "30d",
      "unit": "ratio",
      "enabled": false,
      "actions": ["optimize", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Blob transaction metrics",
        "aws": "S3 request metrics",
        "gcp": "GCS request operations"
      }
    },
    {
      "service_type": "storage",
      "layer": 1,
      "sub_layer": "Self-Contained Storage",
      "type": "Premium Storage Misuse",
      "key": "premium-misuse",
      "category": "cost",
      "description": "Detect workloads on premium storage with low IOPS utilization",
      "module": "premium_misuse",
      "metric": "IOPS vs provisioned",
      "threshold": "<20%",
      "period": "na",
      "unit": "iops",
      "enabled": false,
      "actions": ["downgrade", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Premium block blob metrics",
        "aws": "EBS Provisioned IOPS",
        "gcp": "PD IOPS"
      }
    },
    {
      "service_type": "storage",
      "layer": 2,
      "sub_layer": "Adjacent",
      "type": "Lifecycle Policy Missing",
      "key": "lifecycle-missing",
      "category": "governance",
      "description": "Detect storage accounts missing lifecycle rules for tiering and retention",
      "module": "lifecycle_missing",
      "metric": "Lifecycle rules count",
      "threshold": "=0",
      "period": "na",
      "unit": "count",
      "enabled": true,
      "actions": ["recommend", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Lifecycle Management config",
        "aws": "S3 Lifecycle Rules",
        "gcp": "GCS Lifecycle"
      }
    },
    {
      "service_type": "storage",
      "layer": 2,
      "sub_layer": "Adjacent",
      "type": "Soft Delete Disabled",
      "key": "softdelete-disabled",
      "category": "data-protection",
      "description": "Identify containers or file shares with soft delete turned off",
      "module": "softdelete_disabled",
      "metric": "Soft delete status",
      "threshold": "disabled",
      "period": "na",
      "unit": "boolean",
      "enabled": false,
      "actions": ["enable", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Soft delete configuration",
        "aws": "S3 versioning + MFA delete",
        "gcp": "GCS retention policies"
      }
    },
    {
      "service_type": "storage",
      "layer": 2,
      "sub_layer": "Adjacent",
      "type": "Replication Optimization",
      "key": "replication-overprovision",
      "category": "cost",
      "description": "Detect accounts using costly replication tiers (RA-GRS) unnecessarily",
      "module": "replication_overprovision",
      "metric": "Replication level",
      "threshold": "downgrade-eligible",
      "period": "na",
      "unit": "type",
      "enabled": false,
      "actions": ["downgrade", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "LRS/ZRS/GRS settings",
        "aws": "S3 Cross-Region Replication",
        "gcp": "Multi-region vs region buckets"
      }
    },
    {
      "service_type": "storage",
      "layer": 2,
      "sub_layer": "Adjacent",
      "type": "Idle File Share Cleanup",
      "key": "idle-file-shares",
      "category": "storage",
      "description": "Identify underutilized or unused Azure File Shares",
      "module": "idle_file_shares",
      "metric": "File share utilization",
      "threshold": "<1%",
      "period": "30d",
      "unit": "percent",
      "enabled": false,
      "actions": ["delete", "snapshot", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Azure Files metrics",
        "aws": "EFS metrics",
        "gcp": "Filestore metrics"
      }
    },
    {
      "service_type": "storage",
      "layer": 2,
      "sub_layer": "Adjacent",
      "type": "Orphaned Private Endpoints",
      "key": "orphaned-private-endpoints",
      "category": "networking",
      "description": "Detect unused private endpoints attached to storage accounts",
      "module": "orphaned_private_endpoints",
      "metric": "Connection status",
      "threshold": "no-connections",
      "period": "14d",
      "unit": "boolean",
      "enabled": false,
      "actions": ["delete", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Private endpoint networking",
        "aws": "VPC endpoint links",
        "gcp": "Private Service Connect"
      }
    },
    {
      "service_type": "storage",
      "layer": 3,
      "sub_layer": "Architecture",
      "type": "Data Hotspot Optimization",
      "key": "data-hotspots",
      "category": "architecture",
      "description": "Identify high cross-region transfer costs from storage hotspots",
      "module": "data_hotspots",
      "metric": "Egress GB",
      "threshold": "high",
      "period": "30d",
      "unit": "gb",
      "enabled": false,
      "actions": ["relocate", "cache", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Storage egress metrics",
        "aws": "S3 transfer out metrics",
        "gcp": "GCS egress metrics"
      }
    },
    {
      "service_type": "storage",
      "layer": 3,
      "sub_layer": "Architecture",
      "type": "Cross-Region Replication Inefficiency",
      "key": "replication-data-mismatch",
      "category": "architecture",
      "description": "Identify scenarios where secondary-region read activity is near zero",
      "module": "replication_data_mismatch",
      "metric": "Secondary read ratio",
      "threshold": "<5%",
      "period": "30d",
      "unit": "percent",
      "enabled": false,
      "actions": ["downgrade", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Read access GRS",
        "aws": "CRR metrics",
        "gcp": "Multi-region access metrics"
      }
    },
    {
      "service_type": "storage",
      "layer": 3,
      "sub_layer": "Architecture",
      "type": "Inactive Data Lake Zones",
      "key": "inactive-zones",
      "category": "architecture",
      "description": "Detect inactive ADLS directories or hierarchies from retired pipelines",
      "module": "inactive_zones",
      "metric": "Last modified time",
      "threshold": ">90d",
      "period": "90d",
      "unit": "days",
      "enabled": false,
      "actions": ["archive", "consolidate", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "ADLS Gen2 metrics",
        "aws": "S3 prefix activity",
        "gcp": "GCS folder-level activity"
      }
    },
    {
      "service_type": "storage",
      "layer": 3,
      "sub_layer": "Architecture",
      "type": "Storage Account Sprawl",
      "key": "storage-sprawl",
      "category": "architecture",
      "description": "Identify unnecessary proliferation of storage accounts",
      "module": "storage_sprawl",
      "metric": "Account count",
      "threshold": "high",
      "period": "na",
      "unit": "count",
      "enabled": false,
      "actions": ["consolidate", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Resource Graph inventory",
        "aws": "S3 bucket inventory",
        "gcp": "GCS buckets"
      }
    },
    {
      "service_type": "storage",
      "layer": 3,
      "sub_layer": "Architecture",
      "type": "Inefficient Access Patterns",
      "key": "inefficient-access",
      "category": "architecture",
      "description": "Detect full blob reads where range reads are more efficient",
      "module": "inefficient_access",
      "metric": "Full read ratio",
      "threshold": ">70%",
      "period": "30d",
      "unit": "percent",
      "enabled": false,
      "actions": ["refactor", "report"],
      "export_formats": ["csv", "json"],
      "providers": {
        "azure": "Blob read metrics",
        "aws": "S3 GET vs Range GET",
        "gcp": "GCS read operations"
      }
    }
  ]
}
