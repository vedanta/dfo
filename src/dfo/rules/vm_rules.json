{
  "optimizations": [
    {
      "layer": 1,
      "sub_layer": "Self-Contained VM",
      "type": "Right-Sizing (CPU)",
      "metric": "CPU utilization",
      "threshold": "<20%",
      "period": "14d",
      "unit": "percent",
      "enabled": true,
      "providers": {
        "azure": "Azure Monitor: Percentage CPU",
        "aws": "AWS: CPUUtilization",
        "gcp": "GCP: cpu/utilization"
      }
    },
    {
      "layer": 1,
      "sub_layer": "Self-Contained VM",
      "type": "Right-Sizing (Memory)",
      "metric": "Memory utilization",
      "threshold": "<30%",
      "period": "14d",
      "unit": "percent",
      "enabled": false,
      "providers": {
        "azure": "Azure Monitor: Memory Percent Used",
        "aws": "AWS: mem_used_percent",
        "gcp": "GCP: memory/percent_used"
      }
    },
    {
      "layer": 1,
      "sub_layer": "Self-Contained VM",
      "type": "Idle VM Detection",
      "metric": "CPU/RAM <5%",
      "threshold": "<5%",
      "period": "7d",
      "unit": "percent",
      "enabled": true,
      "providers": {
        "azure": "CPU% + RAM% time series",
        "aws": "AWS: CPUUtilization + mem_used_percent",
        "gcp": "GCP: low CPU+RAM"
      }
    },
    {
      "layer": 1,
      "sub_layer": "Self-Contained VM",
      "type": "Shutdown Detection",
      "metric": "Powered-off days",
      "threshold": "0",
      "period": "30d",
      "unit": "days",
      "enabled": true,
      "providers": {
        "azure": "Azure powerState timeline",
        "aws": "AWS: EC2 state transition",
        "gcp": "GCP: stopped timestamp"
      }
    },
    {
      "layer": 1,
      "sub_layer": "Self-Contained VM",
      "type": "Family Optimization",
      "metric": "CPU/mem fit",
      "threshold": "mismatch>30%",
      "period": "na",
      "unit": "ratio",
      "enabled": false,
      "providers": {
        "azure": "Azure SKU API",
        "aws": "AWS instance types",
        "gcp": "GCP machine types"
      }
    },
    {
      "layer": 1,
      "sub_layer": "Self-Contained VM",
      "type": "Generation Upgrade",
      "metric": "Price/performance",
      "threshold": "improve",
      "period": "na",
      "unit": "index",
      "enabled": false,
      "providers": {
        "azure": "Azure Retail API",
        "aws": "AWS Pricing API",
        "gcp": "GCP Catalog"
      }
    },
    {
      "layer": 1,
      "sub_layer": "Self-Contained VM",
      "type": "Reserved Instance Optimization",
      "metric": "Commit coverage",
      "threshold": "<70%",
      "period": "30d",
      "unit": "percent",
      "enabled": false,
      "providers": {
        "azure": "Azure Reservation Utilization",
        "aws": "AWS RI/SP utilization",
        "gcp": "GCP CUD report"
      }
    },
    {
      "layer": 1,
      "sub_layer": "Self-Contained VM",
      "type": "Spot Optimization",
      "metric": "Interruption rate",
      "threshold": ">10%",
      "period": "na",
      "unit": "percent",
      "enabled": false,
      "providers": {
        "azure": "Azure Spot eviction API",
        "aws": "AWS spot interruption",
        "gcp": "GCP preemptible events"
      }
    },
    {
      "layer": 1,
      "sub_layer": "Self-Contained VM",
      "type": "OS Cost Optimization",
      "metric": "Linux vs Windows delta",
      "threshold": "linux>30%cheaper",
      "period": "na",
      "unit": "usd/hr",
      "enabled": false,
      "providers": {
        "azure": "Azure Retail API",
        "aws": "AWS Pricing",
        "gcp": "GCP Catalog"
      }
