      "period": "na",
      "unit": "usd/core",
      "enabled": false,
      "providers": {
        "azure": "Core count + license model",
        "aws": "AWS SQL/Windows licensing",
        "gcp": "GCP vCPU license"
      }
    },
    {
      "layer": 2,
      "sub_layer": "Adjacent",
      "type": "Disk Tiering",
