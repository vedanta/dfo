# Azure Service Principal for dfo
# Generated by: tools/azure/setup-service-principal.sh
#
# Copy this file to ../../.env and fill in your actual credentials
# DO NOT commit .env to git!

# Azure Authentication
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_SUBSCRIPTION_ID=your-subscription-id-here

# Optional: Analysis Configuration (uncomment to override defaults)
# DFO_IDLE_CPU_THRESHOLD=5.0                # CPU % threshold for idle VM detection
# DFO_IDLE_DAYS=14                          # Days below threshold to consider idle
# DFO_RIGHTSIZING_CPU_THRESHOLD=20.0        # CPU % threshold for rightsizing
# DFO_SHUTDOWN_DAYS=30                      # Days stopped to recommend deletion

# Optional: Database Configuration
# DFO_DUCKDB_FILE=./dfo.duckdb              # Path to DuckDB database file

# Optional: Logging
# DFO_LOG_LEVEL=INFO                        # Log level: DEBUG, INFO, WARNING, ERROR
